# Select one Alterios instance profile. A profile is not a project; it is the
# instance connection and auth context.
ALTERIOS_PROFILE=primary

# Optional explicit registry for multiple Alterios instances. Profiles can also
# be auto-discovered from ALTERIOS_<PROFILE>_* variables below.
ALTERIOS_PROFILES=primary,secondary

# Instance-scoped connection settings for profile "primary".
ALTERIOS_PRIMARY_BASE_URL=https://primary.example
ALTERIOS_PRIMARY_API_TOKEN=put-token-here

# Optional default project id for repetitive local work only.
# Project-scoped tools should still accept and prefer explicit project_id.
ALTERIOS_PRIMARY_PROJECT_ID=put-optional-default-project-id-here

ALTERIOS_PRIMARY_ENDPOINT_TEMPLATE={base_url}/api/scripts/execute-manual
ALTERIOS_PRIMARY_BODY_STYLE=manual_script
ALTERIOS_PRIMARY_AUTH_HEADER=x-api-key
ALTERIOS_PRIMARY_AUTH_SCHEME=
ALTERIOS_PRIMARY_TIMEOUT_SECONDS=20

# A second Alterios instance profile can live in the same private dotenv file.
# Switch per call with --profile secondary or MCP tool argument profile="secondary".
ALTERIOS_SECONDARY_BASE_URL=https://alterios-secondary.example.local
ALTERIOS_SECONDARY_API_TOKEN=put-token-here
ALTERIOS_SECONDARY_PROJECT_ID=put-optional-default-project-id-here
ALTERIOS_SECONDARY_ENDPOINT_TEMPLATE={base_url}/api/scripts/execute-manual
ALTERIOS_SECONDARY_BODY_STYLE=manual_script
ALTERIOS_SECONDARY_AUTH_HEADER=Authorization
ALTERIOS_SECONDARY_AUTH_SCHEME=Bearer
ALTERIOS_SECONDARY_TIMEOUT_SECONDS=20

# Set ALTERIOS_DOTENV_PATH outside this file, for example in shell or Codex MCP
# config, when secrets already live in another private dotenv file. Do not copy
# production secrets into this repository.
# ALTERIOS_DOTENV_PATH=C:\Path\To\AlteriosWorkspace\.env

# Keep write mode disabled unless you are intentionally operating on a safe
# target profile and have verified it with alterios_config first.
ALTERIOS_MCP_ALLOW_WRITE=0

# Required in addition to ALTERIOS_MCP_ALLOW_WRITE for delete, security, role,
# user and other explicitly destructive operations.
ALTERIOS_MCP_ALLOW_DANGEROUS_WRITE=0

# Limit the MCP schema exposed to the client. Use live for normal Alterios
# delivery, discovery for read-only inventory, admin for administrative typed
# tools, and full only for development or route research.
ALTERIOS_MCP_TOOL_PROFILE=live

# Live scenario evidence is verified against the private Gitea work item.
# Keep the three independent delivery roles unless a controlled workflow has a
# documented reason to use another explicit role list.
ALTERIOS_MCP_REQUIRED_AGENT_ROLES=analyst,implementer,verifier

# Read-only project health snapshots are reused for this many seconds unless a
# caller explicitly requests refresh.
ALTERIOS_MCP_HEALTH_CACHE_TTL_SECONDS=300

# Optional private Gitea workboard for real project tasks. Keep the repository
# private and do not put real project data into the public alterios-mcp repo.
GITEA_BASE_URL=https://gitea.example.local
GITEA_TOKEN=put-token-here
GITEA_OWNER=alterios-team
GITEA_REPO=alterios-workboard
GITEA_DEFAULT_PROJECT=put-project-board-id-here
GITEA_DEFAULT_MILESTONE=2026-07-S1
GITEA_TIMEOUT_SECONDS=20

# Optional bridge for Gitea Projects board sync when the board API is not
# published in swagger. Keep real cookies only in a private .env, never in Git.
GITEA_BOARD_COOKIE_FILE=
GITEA_BOARD_COOKIE_HEADER=
GITEA_BOARD_CSRF_TOKEN=

# Gitea issue/comment/label writes are separate from Alterios writes.
# Keep disabled unless you intentionally publish to the private workboard.
GITEA_MCP_ALLOW_WRITE=0

# Optional local private workboard fallback when Gitea is unavailable.
# Keep this outside the public repository when it contains real project data.
LOCAL_WORKBOARD_DIR=~/Documents/AlteriosCodex/workboard
